.pl-container { font-family: 'Roboto Flex', 'Roboto', sans-serif; color: #333; width: 100%; min-height: 100vh; padding: 20px 8px; }
.pl-body { max-width: 800px; margin: 0 auto; width: 100%; }

.pl-page-title { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
.pl-page-title h2 { margin: 0; color: #008ed3; text-transform: uppercase; font-size: 18px; letter-spacing: 1px; }
.pl-status { padding: 6px 12px; border-radius: 12px; font-size: 11px; font-weight: bold; }
.pl-status.loading { background: #d3ca17; color: #111; }
.pl-status.ready { background: #28a745; color: white; }
.pl-status.error { background: #dc3545; color: white; }

.pl-search-wrapper { position: relative; margin-bottom: 20px; }
.pl-search-icon { position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: #999; pointer-events: none; }
.pl-search-box { width: 100%; padding: 14px 20px 14px 48px; border-radius: 8px; border: 1px solid #ccc; font-size: 16px; outline: none; transition: border-color 0.2s; }
.pl-search-box:focus { border-color: #008ed3; }

.pl-program-list { display: flex; flex-direction: column; gap: 12px; }

.pl-program-card { background: white; border: 1px solid #ddd; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.05); transition: box-shadow 0.2s; }
.pl-program-card:hover { box-shadow: 0 4px 16px rgba(0,142,211,0.1); }

.pl-program-header { display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; cursor: pointer; }
.pl-program-name { font-size: 17px; font-weight: bold; color: #111; }
.pl-program-meta { display: flex; gap: 12px; margin-top: 4px; }
.pl-meta-badge { font-size: 11px; color: #888; background: #f4f6f8; padding: 3px 8px; border-radius: 10px; }
.pl-chevron { color: #008ed3; transition: transform 0.2s; }
.pl-chevron.expanded { transform: rotate(180deg); }

.pl-actions { display: flex; gap: 8px; align-items: center; }
.pl-assign-btn { background: #008ed3; color: white; border: none; padding: 8px 14px; border-radius: 6px; cursor: pointer; font-size: 12px; font-weight: bold; text-transform: uppercase; display: flex; align-items: center; gap: 4px; transition: 0.2s; }
.pl-assign-btn:hover { background: #007bc7; }
.pl-delete-btn { background: #fee; color: #dc3545; border: 1px solid #fcc; padding: 8px 14px; border-radius: 6px; cursor: pointer; font-size: 12px; font-weight: bold; text-transform: uppercase; display: flex; align-items: center; gap: 4px; transition: 0.2s; }
.pl-delete-btn:hover { background: #dc3545; color: white; }

.pl-expand { border-top: 1px solid #eee; padding: 20px; }
.pl-phase-section { margin-bottom: 16px; }
.pl-phase-title { font-size: 13px; font-weight: bold; text-transform: uppercase; color: #008ed3; margin-bottom: 8px; padding-bottom: 4px; border-bottom: 2px solid #f0f0f0; }
.pl-exercise-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid #f8f8f8; font-size: 14px; }
.pl-ex-name { font-weight: bold; color: #111; }
.pl-ex-detail { color: #888; font-size: 12px; }
.pl-ex-sets { color: #008ed3; font-weight: bold; }

.pl-assign-modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6); z-index: 9999; display: flex; align-items: center; justify-content: center; padding: 20px; }
.pl-assign-content { background: white; border-radius: 12px; padding: 24px; max-width: 400px; width: 100%; box-shadow: 0 10px 40px rgba(0,0,0,0.3); }
.pl-assign-title { font-size: 18px; font-weight: bold; color: #008ed3; margin-bottom: 16px; }
.pl-assign-select { width: 100%; padding: 12px; font-size: 16px; border: 1px solid #ccc; border-radius: 6px; margin-bottom: 16px; outline: none; }
.pl-assign-select:focus { border-color: #008ed3; }
.pl-assign-actions { display: flex; gap: 10px; }
.pl-assign-confirm { flex: 1; background: #008ed3; color: white; border: none; padding: 12px; border-radius: 6px; cursor: pointer; font-weight: bold; text-transform: uppercase; font-size: 13px; transition: 0.2s; }
.pl-assign-confirm:hover { background: #007bc7; }
.pl-assign-cancel { flex: 1; background: #f4f6f8; color: #555; border: 1px solid #ddd; padding: 12px; border-radius: 6px; cursor: pointer; font-weight: bold; text-transform: uppercase; font-size: 13px; transition: 0.2s; }
.pl-assign-cancel:hover { background: #e8eaed; }

.pl-toast { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); background: #28a745; color: white; padding: 12px 24px; border-radius: 8px; font-size: 14px; font-weight: bold; z-index: 10000; box-shadow: 0 4px 20px rgba(0,0,0,0.2); display: flex; align-items: center; gap: 8px; }
.pl-toast.error { background: #dc3545; }

.pl-placeholder { text-align: center; color: #888; padding: 40px; }
.pl-error { text-align: center; color: #dc3545; padding: 40px; }

/* Privacy Filter Tabs */
.pl-privacy-tabs { display: flex; gap: 8px; margin-bottom: 16px; }
.pl-privacy-tab { padding: 8px 16px; background: #f5f5f5; border: 1px solid #ddd; border-radius: 6px; cursor: pointer; font-size: 13px; font-weight: 600; color: #555; transition: all 0.15s; }
.pl-privacy-tab:hover:not(.active) { background: #e9ecef; }
.pl-privacy-tab.active { background: #008ed3; color: white; border-color: #008ed3; }

/* Privacy Badges */
.pl-privacy-badge { display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
.pl-privacy-public { background: #e8f5e9; color: #2e7d32; }
.pl-privacy-private { background: #fff3e0; color: #e65100; }
.pl-privacy-assigned { background: #e3f2fd; color: #1565c0; }

/* Bulk Assign Button */
.pl-bulk-assign-btn { display: flex; align-items: center; gap: 6px; padding: 10px 16px; background: #008ed3; color: white; border: none; border-radius: 6px; font-size: 14px; font-weight: 600; cursor: pointer; transition: background 0.15s; }
.pl-bulk-assign-btn:hover { background: #0077b5; }

/* Updated Modal Close */
.pl-assign-close { position: absolute; top: 16px; right: 16px; background: none; border: none; cursor: pointer; color: #888; display: flex; }
.pl-assign-close:hover { color: #333; }

/* Modal Steps */
.pl-assign-step { margin-bottom: 20px; padding: 14px; background: #fafafa; border-radius: 6px; border: 1px solid #eee; }
.pl-assign-step h4 { margin: 0 0 10px 0; font-size: 14px; color: '#555'; font-weight: 600; }
.pl-multi-select { width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 13px; min-height: 100px; }

/* Confirm Button */
.pl-assign-confirm-btn { width: 100%; padding: 14px; background: #008ed3; color: white; border: none; border-radius: 6px; font-size: 15px; font-weight: 600; cursor: pointer; margin-top: 10px; }
.pl-assign-confirm-btn:hover { background: #0077b5; }
.pl-assign-confirm-btn:disabled { opacity: 0.5; cursor: not-allowed; }
